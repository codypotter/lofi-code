# Ignore all HTML files in the public directory recursively
public/**/*.html

# Except for the public/admin/index.html file
!public/admin/index.html

# Ignore generated templ files
*_templ.go

# Ignore built assets (generated by npm run build)
public/assets/main*.css
public/assets/main*.js
public/assets/manifest.json

# Node
node_modules/

generate